# Dashboard — identifiants ADMIN (voit tous les clients), via la page /login
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=un-mot-de-passe-fort

# Signature des cookies de session du dashboard (chaîne aléatoire longue)
SESSION_SECRET=une-chaine-aleatoire-longue-64-hex

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=une-chaine-aleatoire-longue

# Logs : debug | info | warn | error (défaut: info)
LOG_LEVEL=info
